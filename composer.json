{
    "name": "social-network/app",
    "description": "A niche social network with real-time messaging",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Social Network Team"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*",
        "ext-redis": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "cboden/ratchet": "^0.4",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^6.8",
        "intervention/image": "^2.7",
        "pusher/pusher-php-server": "^7.2",
        "predis/predis": "^2.2",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "analyse": "phpstan analyse src tests",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
